# ============================================================
# finagent-research 环境变量模板
# 用法：cp .env.example .env，填入真实值
# ============================================================

# ===== 大模型（DeepSeek，可与 finagent-core 共用同一个 key）=====
DEEPSEEK_API_KEY=sk-在这里填你的DeepSeek密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== 网络搜索（二选一或都填，DeepScout 用）=====
# 博查AI（推荐，中文搜索好）：https://open.bochaai.com
BOCHAAI_API_KEY=
# Tavily（备选）：https://tavily.com
TAVILY_API_KEY=
# 搜索提供商：bochaai / tavily
SEARCH_PROVIDER=bochaai

# ===== Redis（检查点/取消信号，复用 finagent-core 的 Redis）=====
REDIS_URL=redis://127.0.0.1:6379/1

# ===== 服务端口 =====
SERVER_HOST=127.0.0.1
SERVER_PORT=8001

# ===== 运行环境 =====
APP_ENV=development
